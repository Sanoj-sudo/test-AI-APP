# Copy this file to `.env` on the server and fill in real secrets.
# NEVER commit the real .env file.

APP_ENV=production
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Postgres
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=appdb

# Redis
REDIS_PASSWORD=changeme-strong-password

# Docker image tag pushed by CI (set automatically in the deploy workflow)
DOCKERHUB_USERNAME=yourdockerhubuser
IMAGE_TAG=latest
