# LOCAL DEV ONLY: copy this file to `.env` for `docker compose up` on your
# machine — compose auto-loads it for variable substitution.
# In PRODUCTION there is NO .env on the server: the deploy workflow forwards
# these values from GitHub Actions secrets into the shell (see deploy.yml).
# Set POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, REDIS_PASSWORD,
# DOCKERHUB_USERNAME (and DOCKERHUB_TOKEN) as repo secrets.
# NEVER commit the real .env file.

APP_ENV=production
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Postgres
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=appdb

# Redis
REDIS_PASSWORD=changeme-strong-password

# Docker image tag pushed by CI (set automatically in the deploy workflow)
DOCKERHUB_USERNAME=yourdockerhubuser
IMAGE_TAG=latest
